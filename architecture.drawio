        <mxCell id="note1" value="&lt;b&gt;Principe du moindre privilège — 2 Service Accounts&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;SA Terraform (infra/config/service_account_key.json) : droits admin GCP, jamais dans les conteneurs&lt;br&gt;SA Airflow (config/gcp/airflow-gcp-key.json) : storage.objectCreator uniquement, monté dans les workers&lt;/font&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fefce8;strokeColor=#ca8a04;fontSize=9;verticalAlign=middle;align=left;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="930" width="560" height="60" as="geometry" />
        </mxCell>

        <mxCell id="note2" value="&lt;b&gt;dbt build = dbt run + dbt test en séquence&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Tests : not_null · unique · accepted_values (macro override apostrophes)&lt;br&gt;Tests singuliers : assert_taux_chomage_valide · assert_couverture_departements · assert_score_desequilibre_positif&lt;/font&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fefce8;strokeColor=#ca8a04;fontSize=9;verticalAlign=middle;align=left;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="600" y="930" width="640" height="60" as="geometry" />
